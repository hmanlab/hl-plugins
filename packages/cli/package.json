{
  "name": "@hmanlab/hl-plugins",
  "version": "0.5.3",
  "description": "One-command installer for curated OpenCode plugins. Adds image, video, music, and speech generation to your coding agent without leaving the chat. MIT, no telemetry.",
  "type": "module",
  "bin": {
    "hl-plugins": "bin/hl-plugins.js"
  },
  "files": [
    "bin",
    "dist",
    "opencode",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "help": "node ./bin/hl-plugins.js help"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "plugin",
    "cli",
    "installer",
    "multimodal",
    "image-generation",
    "video-generation",
    "music-generation",
    "text-to-speech",
    "mmx",
    "MiniMax",
    "token-plan"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hmanlab/hl-plugins.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/hmanlab/hl-plugins#readme",
  "bugs": {
    "url": "https://github.com/hmanlab/hl-plugins/issues"
  }
}
