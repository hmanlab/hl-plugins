{
  "name": "@hmanlab/memo",
  "version": "0.5.1",
  "description": "Local-first MCP server for persistent, persona-aware memory across projects.",
  "type": "module",
  "files": [
    "bin",
    "claude",
    "dist",
    "node_modules",
    "README.md"
  ],
  "scripts": {
    "build": "bun build ./src/server.ts --target=bun --outfile=./dist/memo-mcp-server.js && bun build ./src/cli/main.ts --target=bun --outfile=./dist/cli.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p . --noEmit",
    "test": "bun test tests/"
  },
  "bin": {
    "hmanlab-memory": "./bin/hmanlab-memory.js"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "adm-zip": "^0.5.16",
    "commander": "^12.1.0",
    "optional": "^0.1.4",
    "yaml": "^2.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "sharp": "0.34.5",
    "typescript": "^5.7.2"
  },
  "hl-plugins": {
    "defaultInstall": false,
    "claudeMcp": "./dist/memo-mcp-server.js",
    "cli": "./dist/cli.js",
    "claudeSkill": "./claude/skill/memo/SKILL.md",
    "requires": [
      {
        "name": "bun",
        "type": "binary",
        "check": "bun --version",
        "install": "curl -fsSL https://bun.sh/install | bash"
      }
    ],
    "postInstall": [],
    "embedder": {
      "name": "MiniLM-L6-v2",
      "sizeMb": 25,
      "purpose": "powers semantic search so paraphrase and typo queries still hit the right memory",
      "tradeoff": {
        "with": "73.3% recall@5",
        "without": "paraphrase queries drop to ~30%",
        "note": "30-seed eval across coding, glossary, and preferences"
      },
      "preInstall": [
        "embedder install"
      ],
      "disableCommand": [
        "embedder disable"
      ]
    }
  }
}
