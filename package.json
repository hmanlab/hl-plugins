{
  "name": "hl-plugins-monorepo",
  "version": "0.3.3",
  "private": true,
  "description": "Curated OpenCode plugins, installable with one command.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "node packages/cli/bin/hl-plugins.js",
    "help": "node packages/cli/bin/hl-plugins.js help",
    "typecheck": "tsc -p packages/cli/tsconfig.json --noEmit",
    "build": "tsc -p packages/cli/tsconfig.json",
    "clean": "rm -rf packages/cli/dist",
    "format": "prettier --write \"**/*.{ts,json}\"",
    "format:check": "prettier --check \"**/*.{ts,json}\"",
    "prepublishOnly": "npm run typecheck && npm run build",
    "publish:cli": "npm run build && npm publish --workspace packages/cli --access public",
    "publish:companion": "npm publish --workspace packages/multiplayer-watch --access public"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.17.8",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.10.2",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  }
}
